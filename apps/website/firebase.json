{
  "hosting": {
    "public": "build",
    "cleanUrls": true,
    "ignore": ["**/.*"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "xxx-info-api",
          "region": "asia-east1",
          "pinTag": true
        }
      }
    ],
    "predeploy": ["pnpm run build"]
  }
}
