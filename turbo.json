{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "outputs": ["build/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": []
    }
  }
}
